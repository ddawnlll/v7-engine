  "brief": {
    "mission": {
      "id": "MISSION-P1",
      "text": "Add four pure-math indicator modules to lib/indicators/: RSI (Wilder's EMA), candle geometry (body_ratio, upper_wick_ratio, lower_wick_ratio), momentum/ROC, and rolling min/max/mean. All functions must be pure transforms over price sequences with no external dependencies, no state, and no imports from v7, alphaforge, or simulation."
    },
    "hardRequirements": [
      {
        "id": "HR001",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "RSI must use Wilder's smoothed EMA (same method as existing lib/indicators/atr.py).",
        "enforcedBy": ["json_schema", "completion_gate_v2", "evidence_ledger"]
      },
      {
        "id": "HR002",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "No external dependencies (no pandas, no numpy, no ta-lib).",
        "enforcedBy": ["command_policy_engine", "admission_gate"]
      },
      {
        "id": "HR003",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "No imports from v7, alphaforge, or simulation.",
        "enforcedBy": ["completion_gate_v2", "evidence_ledger"]
      },
      {
        "id": "HR004",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "All NaN/edge case behavior must match the spec in each workstream.",
        "enforcedBy": ["completion_gate_v2", "evidence_ledger"]
      },
      {
        "id": "HR005",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "Existing tests must not break.",
        "enforcedBy": ["final_promotion_gate", "evidence_ledger"]
      },
      {
        "id": "HR006",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "Import boundary test must pass.",
        "enforcedBy": ["evidence_ledger", "completion_gate_v2"]
      },
      {
        "id": "HR007",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "Worktree isolation must be enabled for parallel workspaces.",
        "enforcedBy": ["admission_gate", "tool_runtime"]
      },
      {
        "id": "HR008",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "Integration queue must serialize merges.",
        "enforcedBy": ["workspace_commit_gate"]
      },
      {
        "id": "HR009",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "git push is forbidden.",
        "enforcedBy": ["command_policy_engine"]
      },
      {
