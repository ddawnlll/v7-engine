    {
      "id": "P1.B",
      "title": "Candle Geometry",
      "waveId": "W1",
      "dependencies": [],
      "role": "implementation",
      "allowedFiles": [
        "lib/indicators/candle.py",
        "lib/indicators/__init__.py",
        "lib/tests/test_indicators_candle.py"
      ],
      "capabilities": {
        "canEdit": [
          "lib/indicators/candle.py",
          "lib/indicators/__init__.py",
          "lib/tests/test_indicators_candle.py"
        ]
      },
      "forbiddenFiles": [
        "package.json",
        "pnpm-lock.yaml",
        ".env",
        ".env.*",
        "node_modules/**",
        ".git/**"
      ],
      "instructions": [
        {
          "id": "WI-P1B-001",
          "priority": "must",
          "kind": "implementation_rule",
          "text": "Implement body_ratio, upper_wick_ratio, lower_wick_ratio in lib/indicators/candle.py.",
          "enforcedBy": ["json_schema", "completion_gate_v2"]
        },
        {
          "id": "WI-P1B-002",
          "priority": "must",
          "kind": "implementation_rule",
          "text": "body_ratio = abs(close-open)/(high-low). NaN when high==low. Doji (open==close) returns 0.0, not NaN.",
          "enforcedBy": ["completion_gate_v2"]
        },
        {
          "id": "WI-P1B-003",
          "priority": "must",
          "kind": "implementation_rule",
          "text": "upper_wick_ratio = (high - max(open,close)) / (high-low). NaN when high==low.",
          "enforcedBy": ["completion_gate_v2"]
        },
        {
          "id": "WI-P1B-004",
          "priority": "must",
          "kind": "implementation_rule",
          "text": "lower_wick_ratio = (min(open,close) - low) / (high-low). NaN when high==low.",
          "enforcedBy": ["completion_gate_v2"]
        },
        {
          "id": "WI-P1B-005",
          "priority": "must",
          "kind": "implementation_rule",
          "text": "All four input sequences must have equal length; raise ValueError on mismatch.",
          "enforcedBy": ["completion_gate_v2"]
        }
      ],
      "acceptanceCriteria": [
        {
          "id": "AC-P1B-001",
          "title": "body_ratio correct",
          "text": "body_ratio returns correct values for known OHLC data.",
          "level": "required",
          "evidenceRequired": true,
          "evidenceTypes": ["source", "test"],
          "validationRefs": ["VAL-P1B-001"]
        },
        {
          "id": "AC-P1B-002",
          "title": "Doji handling",
          "text": "Doji candle (open==close) returns body_ratio=0.0 (not NaN).",
          "level": "required",
          "evidenceRequired": true,
          "evidenceTypes": ["test"],
          "validationRefs": ["VAL-P1B-001"]
        },
        {
