      "instructions": [
        {
          "id": "WI-P1A-001",
          "priority": "must",
          "kind": "implementation_rule",
          "text": "Implement rsi(prices: Sequence[float], period: int = 14) -> list[float] using Wilder's smoothed EMA for average gain/loss.",
          "enforcedBy": ["json_schema", "completion_gate_v2"]
        },
        {
          "id": "WI-P1A-002",
          "priority": "must",
          "kind": "implementation_rule",
          "text": "First `period` values must be NaN. Empty input returns empty list. period=1 returns all NaN.",
          "enforcedBy": ["completion_gate_v2", "evidence_ledger"]
        },
        {
          "id": "WI-P1A-003",
          "priority": "must",
          "kind": "implementation_rule",
          "text": "Zero/negative prices produce NaN for affected indices.",
          "enforcedBy": ["completion_gate_v2"]
        }
      ],
      "acceptanceCriteria": [
        {
          "id": "AC-P1A-001",
          "title": "RSI function signature",
          "text": "rsi(prices: Sequence[float], period: int = 14) -> list[float]",
          "level": "required",
          "evidenceRequired": true,
          "evidenceTypes": ["source", "test"],
          "validationRefs": ["VAL-P1A-001"]
        },
        {
          "id": "AC-P1A-002",
          "title": "Wilder's smoothed EMA",
          "text": "Uses Wilder's smoothed EMA for average gain/loss (same method as existing compute_atr).",
          "level": "required",
          "evidenceRequired": true,
          "evidenceTypes": ["source", "test"],
          "validationRefs": ["VAL-P1A-001"]
        },
        {
          "id": "AC-P1A-003",
          "title": "NaN prefix",
          "text": "First `period` values are NaN.",
          "level": "required",
          "evidenceRequired": true,
          "evidenceTypes": ["test"],
          "validationRefs": ["VAL-P1A-001"]
        },
        {
          "id": "AC-P1A-004",
          "title": "Edge cases",
          "text": "Empty input returns empty list. period=1 returns all NaN.",
          "level": "required",
          "evidenceRequired": true,
          "evidenceTypes": ["test"],
          "validationRefs": ["VAL-P1A-001"]
        },
        {
          "id": "AC-P1A-005",
          "title": "RSI range",
          "text": "RSI values are in [0, 100] for valid inputs.",
          "level": "required",
          "evidenceRequired": true,
          "evidenceTypes": ["test"],
          "validationRefs": ["VAL-P1A-001"]
        }
      ],
