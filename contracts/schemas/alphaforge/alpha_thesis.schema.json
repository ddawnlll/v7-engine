{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://v7-engine/contracts/schemas/alphaforge/alpha_thesis.schema.json",
  "title": "AlphaThesis",
  "description": "A formal alpha thesis — an evidence-backed hypothesis about a market anomaly that may have predictive value. Owned by AlphaForge.",
  "type": "object",
  "required": [
    "schema_version",
    "alpha_thesis_id",
    "title",
    "mode",
    "hypothesis",
    "expected_edge_mechanism",
    "required_data",
    "required_features",
    "risk_factors",
    "rejection_criteria",
    "status",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version for compatibility tracking."
    },
    "alpha_thesis_id": {
      "type": "string",
      "description": "Unique identifier for this alpha thesis."
    },
    "title": {
      "type": "string",
      "description": "Short, descriptive title of the thesis."
    },
    "mode": {
      "type": "string",
      "enum": ["SCALP", "AGGRESSIVE_SCALP", "SWING"],
      "description": "Trading mode this thesis targets."
    },
    "hypothesis": {
      "type": "string",
      "description": "The core hypothesis — what anomaly is believed to exist and why."
    },
    "expected_edge_mechanism": {
      "type": "string",
      "description": "Explanation of WHY this anomaly should produce positive expectancy (behavioral, structural, informational, etc.)."
    },
    "required_data": {
      "type": "object",
      "description": "Data requirements for testing this thesis.",
      "properties": {
        "symbols": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required symbols."
        },
        "intervals": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required candle intervals."
        },
        "min_history_bars": {
          "type": "integer",
          "description": "Minimum bars of history required."
        },
        "additional_data": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Any additional data requirements."
        }
      }
    },
    "required_features": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Feature groups or specific features needed to express this thesis."
    },
    "risk_factors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Known or suspected risk factors that could invalidate this thesis."
    },
    "rejection_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit criteria that would cause this thesis to be rejected. Must be falsifiable."
    },
    "status": {
      "type": "string",
      "enum": ["PROPOSED", "DATA_READY", "FEATURED", "SIMULATED", "TRAINED", "VALIDATED", "V7_CANDIDATE", "REJECTED", "ARCHIVED"],
      "description": "Current lifecycle state."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of thesis creation."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update."
    },
    "author": {
      "type": "string",
      "description": "Who proposed this thesis."
    },
    "references": {
      "type": "array",
      "items": { "type": "string" },
      "description": "External references, papers, or sources supporting this thesis."
    },
    "notes": {
      "type": "string",
      "description": "Additional notes or context."
    }
  }
}
