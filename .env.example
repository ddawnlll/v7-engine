# =============================================================================
# V7 Engine — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# WARNING: Never commit the actual .env file.  It contains secrets.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────
# PostgreSQL connection URL. Required for production; defaults to sqlite://
# for local/dev when absent.
# DATABASE_URL=postgresql://user:password@host:5432/v7_engine
# Legacy aliases (resolved in order: V4_DATABASE_URL > V4_POSTGRES_URL > V3_POSTGRES_URL > DATABASE_URL):
# V4_DATABASE_URL=postgresql://user:password@host:5432/v7_engine
# V4_POSTGRES_URL=postgresql://user:password@host:5432/v7_engine
# V3_POSTGRES_URL=postgresql://user:password@host:5432/v7_engine

# ── Environment ──────────────────────────────────────────────────────
# Runtime environment: development | staging | production
ENVIRONMENT=development

# ── API Server ───────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000

# ── Exchange Credentials (Binance) ───────────────────────────────────
# Create API keys at: https://www.binance.com/en/support/faq/how-to-create-api-keys-on-binance-360002502072
#
# Legacy format (used by some bootstrap paths):
# BINANCE_API_KEY=
# BINANCE_SECRET=
#
# Preferred format: credential_ref-based env vars.
# Each runtime profile's `credential_ref` is converted to an UPPER_SNAKE_CASE
# prefix. For the seeded "binance-usdm-main" profile the prefix is
# BINANCE_USDM_MAIN. Set the following for that profile:
BINANCE_USDM_MAIN_API_KEY=
BINANCE_USDM_MAIN_API_SECRET=
# BINANCE_USDM_MAIN_BASE_URL=

# ── AI / LLM Services ───────────────────────────────────────────────
# Required for the failure classifier (Anthropic Claude API).
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Logging ──────────────────────────────────────────────────────────
# Root log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Output format: "json" (default) or "text" (key=value lines)
# LOG_FORMAT=json
# Directory for rotated log files (10 MB per file, 5 backups kept)
# LOG_DIR=./logs
# Optional per-module overrides: "module.a=DEBUG,module.b=WARNING"
# LOG_LEVELS=
# HTTP header to read request-id from (propagated to every log line)
# LOG_REQUEST_ID_HEADER=X-Request-ID

# ── Paper Trading ────────────────────────────────────────────────────
# V4_PAPER_STARTING_CASH=100.0

# ── HTTP / Proxy ─────────────────────────────────────────────────────
# RUNTIME_HTTP_TRUST_ENV=false

# ── Data Paths ───────────────────────────────────────────────────────
# Override default data storage location if needed.
# DATA_DIR=./data
