  "alpha_thesis": {
    "id": "ath-scalp-bb-position-mean-reversion-v2",
    "title": "BB Position Dominated Mean-Reversion Edge — SCALP 1h (Real Data)",
    "status": "VALIDATED_ON_REAL_DATA",
    "evidence_quality": "MODERATE",
    "description": "bb_position = normalized location of close within Bollinger Bands. Near upper band (bb_position≈1) → mean-reversion sell signal (SHORT). Near lower band (bb_position≈0) → mean-reversion buy signal (LONG). The 16-feature XGBoost model on REAL Binance data (4 symbols, 118K 1h bars) learns a threshold/regime-dependent version of this strategy where bb_position carries 97.3% of predictive power (DoubleEnsemble shuffle ablation).",
    "primary_driver": {
      "feature": "bb_position",
      "formula": "bb_position[t] = (close[t] - lower[t]) / (upper[t] - lower[t])",
      "bands_formula": "upper[t] = SMA(close, window=20) + 2.0 × rolling_std(close, window=20); lower[t] = SMA(close, window=20) - 2.0 × rolling_std(close, window=20)",
      "causality": "uses close[t-window+1 .. t] only — causal, no lookahead",
      "shuffle_impact_pct": 97.30,
      "leakage_audit": "CLEAN — verified on real Binance data"
    },
    "secondary_features": [
      {"name": "ofi_N", "formula": "Order Flow Imbalance normalized", "shuffle_impact_pct": 26.53},
      {"name": "atr_expansion_N", "formula": "Rate of change of ATR", "shuffle_impact_pct": 20.87},
      {"name": "return_zscore_N", "formula": "Z-score of recent returns", "shuffle_impact_pct": 7.51},
      {"name": "vwap_mid_deviation_N", "formula": "(close[t] - vwap[t]) / vwap[t]", "shuffle_impact_pct": 7.21},
      {"name": "trade_count_N", "formula": "Normalized trade count", "shuffle_impact_pct": 6.64},
      {"name": "multi_level_obi_N", "formula": "Multi-level Order Book Imbalance", "shuffle_impact_pct": 6.60},
      {"name": "microprice_N", "formula": "Microprice = (bid+ask)/2 weighted", "shuffle_impact_pct": 6.55},
      {"name": "log_return_1", "formula": "Log return over 1 bar", "shuffle_impact_pct": 5.74}
    ]
  },

