{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/planspec/v5-alpha2/planspec.schema.json",
  "title": "PlanSpec v5 Alpha2 Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "planSpecVersion",
    "kind",
    "metadata",
    "compatibility",
    "intent",
    "authority",
    "enforcementRegistry",
    "security",
    "commands",
    "locking",
    "brief",
    "waves",
    "workspaces",
    "validation",
    "evidence",
    "reports"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "planSpecVersion": {
      "const": "5.0.0-alpha2"
    },
    "kind": {
      "const": "ImplementationPlan"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "intent": {
      "$ref": "#/$defs/intent"
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executionState",
        "completion",
        "repositoryMutation",
        "reports"
      ],
      "properties": {
        "executionState": {
          "type": "object",
          "additionalProperties": true
        },
        "completion": {
          "type": "object",
          "additionalProperties": true
        },
        "repositoryMutation": {
          "type": "object",
          "additionalProperties": true
        },
        "reports": {
          "type": "object",
          "additionalProperties": true
        },
        "routing": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "enforcementRegistry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mechanisms"
      ],
      "properties": {
        "mechanisms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaValidationRequired",
        "lockRequiredForExecution",
        "canonicalJsonHashRequired",
        "signatureRequired",
        "hardStops",
        "forbiddenFiles"
      ],
      "properties": {
        "schemaValidationRequired": {
          "type": "boolean"
        },
        "lockRequiredForExecution": {
          "type": "boolean"
        },
        "canonicalJsonHashRequired": {
          "type": "boolean"
        },
        "signatureRequired": {
          "type": "boolean"
        },
        "signatureAlgorithm": {
          "type": "string"
        },
        "hardStops": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operatorNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "commands": {
      "$ref": "#/$defs/commands"
    },
    "locking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lockVersion",
        "lockFile",
        "lockRequired",
        "workerMustEchoPlanLockHash",
        "workerMustEchoWorkspaceLockHash",
        "hashes",
        "lifecycle",
        "mutationRules"
      ],
      "properties": {
        "lockVersion": {
          "type": "string"
        },
        "lockFile": {
          "type": "string"
        },
        "lockRequired": {
          "type": "boolean"
        },
        "workerMustEchoPlanLockHash": {
          "type": "boolean"
        },
        "workerMustEchoWorkspaceLockHash": {
          "type": "boolean"
        },
        "hashes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lifecycle": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mutationRules": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "brief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission",
        "hardRequirements",
        "antiPatterns",
        "operatorNotes"
      ],
      "properties": {
        "mission": {
          "$ref": "#/$defs/instruction"
        },
        "hardRequirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/instruction"
          }
        },
        "antiPatterns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/briefNote"
          }
        },
        "operatorNotes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/briefNote"
          }
        }
      }
    },
    "waves": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/wave"
      }
    },
    "workspaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workspace"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finalRequired",
        "watchModeForbidden",
        "noTestsFoundIsFailure",
        "commandEvidenceRequired",
        "forbiddenPatterns",
        "finalValidationCommandRefs",
        "discoveryCommandsMayNotSatisfyFinalValidation"
      ],
      "properties": {
        "finalRequired": {
          "type": "boolean"
        },
        "watchModeForbidden": {
          "type": "boolean"
        },
        "noTestsFoundIsFailure": {
          "type": "boolean"
        },
        "commandEvidenceRequired": {
          "type": "boolean"
        },
        "forbiddenPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "finalValidationCommandRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "discoveryCommandsMayNotSatisfyFinalValidation": {
          "type": "boolean"
        },
        "accpRequiredArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ledgerRequired",
        "confidenceEnum",
        "requiredEvidenceTypes",
        "evidenceItemRequiredFields",
        "hashWhenAvailable"
      ],
      "properties": {
        "ledgerRequired": {
          "type": "boolean"
        },
        "confidenceEnum": {
          "type": "array",
          "items": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        },
        "requiredEvidenceTypes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidenceItemRequiredFields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hashWhenAvailable": {
          "type": "boolean"
        },
        "accpArtifactHashRequired": {
          "type": "boolean"
        }
      }
    },
    "reports": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "version",
        "required"
      ],
      "properties": {
        "protocol": {
          "const": "ACCP"
        },
        "version": {
          "type": "string"
        },
        "required": {
          "type": "array"
        },
        "artifactDirectory": {
          "type": "string"
        },
        "stableIdsRequired": {
          "type": "boolean"
        },
        "commandEvidenceRequired": {
          "type": "boolean"
        },
        "rollbackPlanRequiredForMutation": {
          "type": "boolean"
        },
        "sourceFormat": {
          "type": "string"
        },
        "reportsAreEvidenceOnly": {
          "type": "boolean"
        },
        "reportsDoNotAuthorizeExecution": {
          "type": "boolean"
        },
        "routeSignalsAreAdvisory": {
          "type": "boolean"
        }
      }
    },
    "p45Bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementationAllowed",
        "allowedArtifactPaths",
        "forbiddenRuntimePaths",
        "artifactExports"
      ],
      "properties": {
        "implementationAllowed": {
          "const": false
        },
        "allowedArtifactPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenRuntimePaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifactExports": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "path"
            ],
            "properties": {
              "type": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "renderHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generatedMarkdownPath": {
          "type": "string"
        },
        "includeBrief": {
          "type": "boolean"
        },
        "includeWaves": {
          "type": "boolean"
        },
        "includeWorkspaces": {
          "type": "boolean"
        },
        "includeAcceptanceCriteria": {
          "type": "boolean"
        },
        "includeValidation": {
          "type": "boolean"
        },
        "markPreviewNonAuthoritative": {
          "type": "boolean"
        }
      }
    },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "strategy": {
          "type": "string"
        },
        "adapterRequired": {
          "type": "boolean"
        },
        "legacyFieldsMapped": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "v411",
              "planspec"
            ],
            "properties": {
              "v411": {
                "type": "string"
              },
              "planspec": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "sourceReferences": {
      "type": "object",
      "additionalProperties": true
    },
    "accp": {
      "type": "object",
      "additionalProperties": true
    },
    "finalPromotion": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phaseId",
        "title",
        "createdAt",
        "status",
        "sourceDocument"
      ],
      "properties": {
        "phaseId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "validated",
            "locked",
            "admitted",
            "running",
            "completed",
            "superseded"
          ]
        },
        "sourceDocument": {
          "type": "string"
        },
        "sourcePackage": {
          "type": "string"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtimeContractVersion",
        "runtimeTemplateVersion",
        "legacyTemplateCompatible",
        "v411AdapterRequired"
      ],
      "properties": {
        "runtimeContractVersion": {
          "type": "string"
        },
        "runtimeTemplateVersion": {
          "type": "string"
        },
        "legacyTemplateCompatible": {
          "type": "boolean"
        },
        "generatedFromV411": {
          "type": "boolean"
        },
        "v411AdapterRequired": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executionClass",
        "safetyLevel",
        "executionMode",
        "parallelism"
      ],
      "properties": {
        "executionClass": {
          "enum": [
            "implementation",
            "repair",
            "validation",
            "research"
          ]
        },
        "safetyLevel": {
          "enum": [
            "relaxed",
            "standard",
            "strict"
          ]
        },
        "executionMode": {
          "type": "string"
        },
        "parallelism": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "targetPromotionMode": {
          "type": "string"
        },
        "p45ImplementationAllowed": {
          "type": "boolean"
        },
        "p50ImplementationAllowed": {
          "type": "boolean"
        },
        "humanReviewRecommended": {
          "type": "boolean"
        },
        "routeBusEnabledByDefault": {
          "type": "boolean"
        },
        "tabModePickerEnabled": {
          "type": "boolean"
        },
        "filePickerGesture": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaValidationRequired",
        "lockRequiredForExecution",
        "canonicalJsonHashRequired",
        "signatureRequired",
        "hardStops",
        "forbiddenFiles"
      ],
      "properties": {
        "schemaValidationRequired": {
          "type": "boolean"
        },
        "lockRequiredForExecution": {
          "type": "boolean"
        },
        "canonicalJsonHashRequired": {
          "type": "boolean"
        },
        "signatureRequired": {
          "type": "boolean"
        },
        "signatureAlgorithm": {
          "type": "string"
        },
        "hardStops": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "defaultMode",
        "shellDefault",
        "exactAllowedCommands",
        "commandClasses",
        "runtimeCommandGrant",
        "hardDeniedCommands",
        "validationEvidenceRules"
      ],
      "properties": {
        "policy": {
          "const": "risk_tiered"
        },
        "defaultMode": {
          "type": "string"
        },
        "shellDefault": {
          "type": "string"
        },
        "exactAllowedCommands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "commandClasses": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "runtimeCommandGrant": {
          "type": "object",
          "additionalProperties": true
        },
        "hardDeniedCommands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "validationEvidenceRules": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "finalPromotionRequiresExactAllowedCommand",
            "discoveryCommandsMayNotSatisfyFinalValidation",
            "runtimeGrantCommandsCanSatisfyValidationOnlyIfGrantStatesValidationPurpose"
          ],
          "properties": {
            "finalPromotionRequiresExactAllowedCommand": {
              "type": "boolean"
            },
            "discoveryCommandsMayNotSatisfyFinalValidation": {
              "type": "boolean"
            },
            "runtimeGrantCommandsCanSatisfyValidationOnlyIfGrantStatesValidationPurpose": {
              "type": "boolean"
            },
            "accpCompileCommandsCanSatisfyAccpValidationOnlyIfArtifactHashRecorded": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "instruction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "priority": {
          "enum": [
            "must",
            "should",
            "may"
          ]
        },
        "kind": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "risk": {
          "type": "string"
        },
        "enforcedBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "briefNote": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "risk": {
          "type": "string"
        },
        "priority": {
          "enum": [
            "must",
            "should",
            "may"
          ]
        },
        "kind": {
          "type": "string"
        },
        "enforcedBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "wave": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "description",
        "workspaceIds",
        "dependencies",
        "batchSize",
        "gate"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "workspaceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "batchSize": {
          "type": "integer"
        },
        "gate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "commandRefs",
            "requiredArtifacts"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "commandRefs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "requiredArtifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "waveId",
        "dependencies",
        "role",
        "allowedFiles",
        "forbiddenFiles",
        "instructions",
        "acceptanceCriteria",
        "validation",
        "reports",
        "rollback"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "waveId": {
          "type": "string"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "role": {
          "type": "string"
        },
        "allowedFiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "forbiddenFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instructions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/instruction"
          }
        },
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": true
        },
        "reports": {
          "type": "object",
          "additionalProperties": true
        },
        "rollback": {
          "type": "object",
          "additionalProperties": true
        },
        "description": {
          "type": "string"
        },
        "risk": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
