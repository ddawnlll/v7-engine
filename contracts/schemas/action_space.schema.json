{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ddawnlll/v7-engine/contracts/schemas/action_space.schema.json",
  "title": "AlphaForge Action Space",
  "description": "Machine-readable encoding of the action space for leverage-aware training (AF-DATA-002, #299). Encodes direction + leverage as discrete integer labels. V0 covers 1x only (legacy); V1 adds 2x/3x/5x for leverage-aware strategies.",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "enum": ["v0", "v1"],
      "description": "Action space version. v0 = legacy 1x flat actions; v1 = leverage-aware."
    },
    "actions": {
      "type": "object",
      "description": "Mapping from human-readable action name to integer label.",
      "properties": {
        "NO_TRADE": {
          "type": "integer",
          "const": 0,
          "description": "No position — default for SCALP/AGGRESSIVE_SCALP."
        },
        "LONG_1X":     { "type": "integer", "const": 1, "description": "Long, 1x leverage (no leverage)." },
        "LONG_2X":     { "type": "integer", "const": 2, "description": "Long, 2x leverage." },
        "LONG_3X":     { "type": "integer", "const": 3, "description": "Long, 3x leverage." },
        "LONG_5X":     { "type": "integer", "const": 4, "description": "Long, 5x leverage." },
        "SHORT_1X":    { "type": "integer", "const": 5, "description": "Short, 1x leverage." },
        "SHORT_2X":    { "type": "integer", "const": 6, "description": "Short, 2x leverage." },
        "SHORT_3X":    { "type": "integer", "const": 7, "description": "Short, 3x leverage." },
        "SHORT_5X":    { "type": "integer", "const": 8, "description": "Short, 5x leverage." }
      },
      "required": ["NO_TRADE", "LONG_1X", "LONG_2X", "LONG_3X", "LONG_5X",
                   "SHORT_1X", "SHORT_2X", "SHORT_3X", "SHORT_5X"],
      "additionalProperties": false
    },
    "joint_encoding": {
      "type": "object",
      "description": "Alternative decomposed encoding — direction and leverage as separate fields.",
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["NO_TRADE", "LONG", "SHORT"]
        },
        "leverage": {
          "type": "integer",
          "enum": [0, 1, 2, 3, 5],
          "description": "Leverage multiplier. 0 = NO_TRADE."
        }
      },
      "required": ["direction", "leverage"]
    }
  },
  "required": ["version", "actions"],
  "additionalProperties": false
}
