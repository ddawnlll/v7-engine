{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://v7-engine/contracts/schemas/alphaforge/v7_handoff_package.schema.json",
  "title": "V7HandoffPackage",
  "description": "The delivery artifact from AlphaForge to V7 acceptance gates. Bundles all evidence V7 needs to evaluate an alpha candidate. Owned by AlphaForge; accepted/rejected by V7.",
  "type": "object",
  "required": [
    "schema_version",
    "handoff_package_id",
    "mode",
    "alpha_candidate_id",
    "mode_research_report_id",
    "validation_report_id",
    "model_artifact_id",
    "calibration_candidate_id",
    "v7_gate_mapping",
    "recommended_status",
    "blocked_scopes",
    "limitations",
    "lineage"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "handoff_package_id": {
      "type": "string",
      "description": "Unique handoff package identifier."
    },
    "mode": {
      "type": "string",
      "enum": ["SCALP", "AGGRESSIVE_SCALP", "SWING"]
    },
    "alpha_candidate_id": {
      "type": "string",
      "description": "AlphaCandidate reference."
    },
    "mode_research_report_id": {
      "type": "string",
      "description": "ModeResearchReport reference."
    },
    "validation_report_id": {
      "type": "string",
      "description": "ValidationReport reference."
    },
    "model_artifact_id": {
      "type": "string",
      "description": "ModelArtifact reference."
    },
    "calibration_candidate_id": {
      "type": "string",
      "description": "CalibrationCandidate reference."
    },
    "v7_gate_mapping": {
      "type": "object",
      "description": "Mapping of AlphaForge evidence to V7 promotion gates (G0-G10).",
      "properties": {
        "G0_data_quality": { "type": "string", "description": "Evidence reference for data quality." },
        "G1_feature_validity": { "type": "string" },
        "G2_label_validity": { "type": "string" },
        "G3_model_sanity": { "type": "string" },
        "G4_oos_performance": { "type": "string" },
        "G5_cost_resilience": { "type": "string" },
        "G6_regime_robustness": { "type": "string" },
        "G7_stability": { "type": "string" },
        "G8_calibration": { "type": "string" },
        "G9_no_trade_baseline": { "type": "string" },
        "G10_paper_shadow": { "type": "string" }
      }
    },
    "recommended_status": {
      "type": "string",
      "enum": ["REVIEW_REQUIRED", "SHADOW_READY", "PROMOTION_CANDIDATE"],
      "description": "AlphaForge recommendation. V7 is NOT bound by this."
    },
    "blocked_scopes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Scopes explicitly blocked/not covered by this package."
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Known limitations."
    },
    "lineage": {
      "type": "object",
      "description": "Full provenance chain from raw data to handoff.",
      "properties": {
        "data_refs": { "type": "array", "items": { "type": "string" } },
        "feature_set_id": { "type": "string" },
        "label_dataset_id": { "type": "string" },
        "simulation_profile_id": { "type": "string" },
        "simulation_run_ids": { "type": "array", "items": { "type": "string" } },
        "training_run_id": { "type": "string" },
        "git_commit": { "type": "string" },
        "lineage_verified": { "type": "boolean" }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "rejection_rules_applied": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Which rejection rules were evaluated and passed before handoff."
    }
  }
}
