# =============================================================================
# V7 Engine — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# WARNING: Never commit the actual .env file.  It contains secrets.
# =============================================================================

# ── Binance API (required for live/online data) ───────────────────
# Create API keys at: https://www.binance.com/en/support/faq/how-to-create-api-keys-on-binance-360002502072
BINANCE_API_KEY=
BINANCE_SECRET=

# ── Data paths ────────────────────────────────────────────────────
# Override default data storage location if needed.
# DATA_DIR=./data

# ── Logging ───────────────────────────────────────────────────────
# LOG_LEVEL=INFO
