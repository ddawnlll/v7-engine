        "enforcedBy": ["admission_gate"]
      }
    ],
    "antiPatterns": [
      {
        "id": "AP001",
        "text": "Do not use simple moving average for RSI — must use Wilder's smoothed EMA.",
        "enforcedBy": ["completion_gate_v2", "evidence_ledger"]
      },
      {
        "id": "AP002",
