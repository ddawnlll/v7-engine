  "brief": {
    "mission": {
      "id": "MISSION-P05",
      "text": "Create a minimal lib/ foundation with shared primitives: Binance data fetching, ATR/returns/volatility indicators, fee/slippage costs, and time utilities. No regime, risk, IO, or adapter logic in lib/."
    },
    "hardRequirements": [
      {
        "id": "HR001",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "lib/ must NOT import v7, alphaforge, or simulation packages.",
        "enforcedBy": ["json_schema", "admission_gate", "import_boundary_test"]
      },
      {
        "id": "HR002",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "No external dependencies (no pandas, no numpy, no ta-lib).",
        "enforcedBy": ["command_policy_engine", "admission_gate"]
      },
      {
        "id": "HR003",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "Binance API calls must originate from lib/market_data/binance/, not from v7/ or alphaforge/.",
        "enforcedBy": ["tool_runtime", "write_gate"]
      },
      {
        "id": "HR004",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "No regime, risk, IO, or adapter logic goes in lib/.",
        "enforcedBy": ["completion_gate_v2", "accp_report_validator"]
      }
    ],
    "antiPatterns": [
      {
        "id": "AP001",
        "text": "Do not put regime enums/detectors in lib/ — v7 uses for policy, alphaforge uses for features.",
        "enforcedBy": ["completion_gate_v2"]
      },
      {
        "id": "AP002",
        "text": "Do not put R-multiple in lib/ — v7 uses ATR+mode truth, research uses fixed %.",
        "enforcedBy": ["completion_gate_v2"]
      },
      {
        "id": "AP003",
        "text": "Do not put IO utilities or generic serialization in lib/ — each system writes output differently.",
        "enforcedBy": ["admission_gate"]
      }
    ],
    "operatorNotes": [
      {
        "id": "ON001",
        "text": "lib/ is curated, not comprehensive. Only primitives with nearly identical usage between v7 and alphaforge belong here."
      },
      {
        "id": "ON002",
        "text": "P0 was a prerequisite — P0.5 depends on P0 completion."
      }
    ]
