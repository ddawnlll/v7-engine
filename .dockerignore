# Git
.git
.gitignore
.gitattributes

# Python
__pycache__
*.pyc
*.pyo
*.egg-info
.eggs
dist
build
*.egg

# Virtual environments
venv
.venv
env
.env
*.env.local

# Node
node_modules
interface/node_modules
interface/dist

# IDE
.idea
.vscode
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Claude
.claude

