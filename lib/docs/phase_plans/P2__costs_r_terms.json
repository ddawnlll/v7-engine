  "brief": {
    "mission": {
      "id": "MISSION-P2",
      "text": "Add fee_cost_r, slippage_cost_r, total_cost_r to lib/costs/ — R-normalized cost functions that call existing lib primitives (estimate_fee from lib.costs.fees, get_slippage from lib.costs.slippage). No reimplementation of underlying cost logic."
    },
    "hardRequirements": [
      {
        "id": "HR001",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "fee_cost_r must call estimate_fee from lib.costs.fees — no reimplementation.",
        "enforcedBy": ["completion_gate_v2", "evidence_ledger"]
      },
      {
        "id": "HR002",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "slippage_cost_r must call get_slippage from lib.costs.slippage — no reimplementation.",
        "enforcedBy": ["completion_gate_v2", "evidence_ledger"]
      },
      {
        "id": "HR003",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "total_cost_r = fee_cost_r + slippage_cost_r (within float epsilon).",
        "enforcedBy": ["completion_gate_v2"]
      },
      {
        "id": "HR004",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "atr=0 returns 0.0 (no division by zero). stop_multiplier=0 returns 0.0. atr < 0 returns 0.0.",
        "enforcedBy": ["completion_gate_v2"]
      },
      {
        "id": "HR005",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "1R = atr * stop_multiplier convention must be used.",
        "enforcedBy": ["json_schema", "completion_gate_v2"]
      },
      {
        "id": "HR006",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "No imports from v7, alphaforge, or simulation.",
        "enforcedBy": ["completion_gate_v2", "evidence_ledger"]
      },
      {
        "id": "HR007",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "Existing tests must not break.",
        "enforcedBy": ["final_promotion_gate"]
      },
      {
        "id": "HR008",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "Import boundary test must pass.",
        "enforcedBy": ["evidence_ledger"]
      },
      {
        "id": "HR009",
        "priority": "must",
        "kind": "implementation_rule",
        "text": "git push is forbidden.",
        "enforcedBy": ["command_policy_engine"]
      }
    ],
    "antiPatterns": [
      {
        "id": "AP001",
        "text": "Do not reimplement fee or slippage calculation — call existing lib.costs.fees and lib.costs.slippage primitives.",
        "enforcedBy": ["completion_gate_v2", "evidence_ledger"]
      },
      {
        "id": "AP002",
        "text": "Do not use fixed R-multiple convention from research — v7 uses ATR * stop_multiplier for 1R.",
        "enforcedBy": ["completion_gate_v2"]
      },
      {
        "id": "AP003",
        "text": "Do not leave atr=0, multiplier=0, or atr<0 unhandled.",
        "enforcedBy": ["completion_gate_v2"]
      }
    ],
    "operatorNotes": [
      {
        "id": "ON001",
        "text": "P2.A is the sole implementation workspace. P2.B is test gates. Serial execution (batch_1 then batch_2) with parallelism target 1."
      },
      {
        "id": "ON002",
        "text": "P2 depends on P1 (lib/indicators/atr.py for ATR) and P0.5 (lib/costs/fees.py, lib/costs/slippage.py for underlying primitives)."
      }
    ]
