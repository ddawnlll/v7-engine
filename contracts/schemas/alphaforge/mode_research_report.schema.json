{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://v7-engine/contracts/schemas/alphaforge/mode_research_report.schema.json",
  "title": "ModeResearchReport",
  "description": "Per-mode research report containing alpha thesis evaluation, validation summary, metrics, cost stress, NO_TRADE comparison, regime breakdown, MHT control, and verdict. Owned by AlphaForge. P0.8E: nested required fields strengthened — empty cost_stress, no_trade_comparison, regime_breakdown, or metrics cannot pass.",
  "type": "object",
  "required": [
    "schema_version",
    "report_id",
    "mode",
    "mode_priority",
    "report_type",
    "data_scope",
    "feature_set_refs",
    "label_dataset_refs",
    "alpha_theses",
    "validation_summary",
    "metrics",
    "cost_stress",
    "no_trade_comparison",
    "regime_breakdown",
    "multiple_hypothesis_control",
    "verdict",
    "blocked_scopes",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version."
    },
    "report_id": {
      "type": "string",
      "description": "Unique report identifier."
    },
    "mode": {
      "type": "string",
      "enum": ["SCALP", "AGGRESSIVE_SCALP", "SWING"]
    },
    "mode_priority": {
      "type": "string",
      "enum": ["PRIMARY", "SECONDARY_BASELINE"]
    },
    "report_type": {
      "type": "string",
      "enum": ["primary_research_report", "secondary_baseline_report"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "run_id": {
      "type": "string",
      "description": "ResearchRunManifest run_id."
    },
    "data_scope": {
      "type": "object",
      "description": "Data scope of this report. P0.8E: primary_timeframes and symbols required.",
      "required": ["symbols", "primary_timeframes"],
      "properties": {
        "symbols": { "type": "array", "items": { "type": "string" } },
        "date_range_start": { "type": "string", "format": "date-time" },
        "date_range_end": { "type": "string", "format": "date-time" },
        "primary_timeframes": { "type": "array", "items": { "type": "string" } },
        "secondary_timeframes": { "type": "array", "items": { "type": "string" } },
        "data_quality_summary": { "type": "string" }
      }
    },
    "feature_set_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "FeatureSetSpec IDs used."
    },
    "label_dataset_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "LabelDatasetSpec IDs used."
    },
    "alpha_theses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["alpha_thesis_id", "status"],
        "properties": {
          "alpha_thesis_id": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "evidence_quality": { "type": "string", "enum": ["STRONG", "MODERATE", "WEAK", "INSUFFICIENT"] }
        }
      },
      "description": "Alpha theses evaluated in this report. P0.8E: each thesis must have id and status."
    },
    "validation_summary": {
      "type": "object",
      "required": ["validation_report_id", "fold_count", "verdict"],
      "properties": {
        "validation_report_id": { "type": "string" },
        "fold_count": { "type": "integer", "description": "P0.8E: minimum 6 folds." },
        "verdict": { "type": "string" },
        "overfit_risk": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Aggregate performance metrics with confidence intervals. P0.8E: oos_expectancy_r, oos_sharpe, oos_trade_count required.",
      "required": ["oos_expectancy_r", "oos_sharpe", "oos_trade_count"],
      "properties": {
        "oos_sharpe": { "$ref": "#/definitions/MetricWithCI" },
        "oos_expectancy_r": { "$ref": "#/definitions/MetricWithCI" },
        "oos_win_rate": { "$ref": "#/definitions/MetricWithCI" },
        "oos_profit_factor": { "$ref": "#/definitions/MetricWithCI" },
        "oos_max_drawdown_r": { "$ref": "#/definitions/MetricWithCI" },
        "oos_trade_count": { "type": "integer" },
        "per_fold_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "fold": { "type": "integer" },
              "sharpe": { "type": "number" },
              "expectancy_r": { "type": "number" },
              "win_rate": { "type": "number" },
              "trade_count": { "type": "integer" }
            }
          }
        }
      }
    },
    "cost_stress": {
      "type": "object",
      "description": "Cost sensitivity analysis. P0.8E: baseline values and combined_stress_edge_survives required — empty cost_stress cannot pass.",
      "required": ["baseline_fee_pct", "baseline_slippage_pct", "combined_stress_edge_survives"],
      "properties": {
        "baseline_fee_pct": { "type": "number" },
        "baseline_slippage_pct": { "type": "number" },
        "fee_stress_levels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "multiplier": { "type": "number" },
              "oos_expectancy_r": { "type": "number" },
              "edge_survives": { "type": "boolean" }
            }
          }
        },
        "slippage_stress_levels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "multiplier": { "type": "number" },
              "oos_expectancy_r": { "type": "number" },
              "edge_survives": { "type": "boolean" }
            }
          }
        },
        "combined_stress_edge_survives": { "type": "boolean" },
        "break_even_cost_total_pct": { "type": "number" }
      }
    },
    "no_trade_comparison": {
      "type": "object",
      "description": "Comparison of active trading vs doing nothing. P0.8E: active_beats_no_trade and summary required — empty no_trade_comparison cannot pass.",
      "required": ["active_beats_no_trade", "summary"],
      "properties": {
        "long_vs_no_trade": { "type": "string", "description": "Is LONG better than NO_TRADE after costs?" },
        "short_vs_no_trade": { "type": "string", "description": "Is SHORT better than NO_TRADE after costs?" },
        "active_beats_no_trade": { "type": "boolean" },
        "summary": { "type": "string" }
      }
    },
    "regime_breakdown": {
      "type": "object",
      "description": "Performance across market regimes. P0.8E: regimes array and edge_only_in_rare_regime required — empty regime_breakdown cannot pass.",
      "required": ["regimes", "edge_only_in_rare_regime"],
      "properties": {
        "regimes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "regime": { "type": "string" },
              "sample_pct": { "type": "number" },
              "oos_expectancy_r": { "type": "number" },
              "edge_present": { "type": "boolean" }
            }
          }
        },
        "edge_only_in_rare_regime": { "type": "boolean" },
        "summary": { "type": "string" }
      }
    },
    "multiple_hypothesis_control": {
      "type": "object",
      "description": "Multiple hypothesis testing and data snooping controls. BLOCKING: NONE_APPLIED or NOT_RUN prevent strong edge/profitability claims.",
      "required": [
        "mht_status",
        "tested_hypothesis_count",
        "tested_feature_count",
        "tested_thesis_count",
        "correction_method",
        "trial_count_disclosure"
      ],
      "properties": {
        "mht_status": {
          "type": "string",
          "enum": ["APPLIED_AND_PASSED", "APPLIED_WITH_WARNINGS", "NOT_RUN", "NONE_APPLIED"],
          "description": "MHT control status. NOT_RUN or NONE_APPLIED: edge/profitability claims are blocked."
        },
        "tested_hypothesis_count": { "type": "integer", "minimum": 0 },
        "tested_feature_count": { "type": "integer", "minimum": 0 },
        "tested_thesis_count": { "type": "integer", "minimum": 0 },
        "correction_method": { "type": "string", "description": "MHT correction method: Bonferroni, Holm-Bonferroni, Benjamini-Hochberg, DeflatedSharpeRatio, PBO, FWER_Control, or NONE." },
        "false_discovery_control": { "type": "string" },
        "deflated_sharpe_or_pbo_assessment": { "type": "string" },
        "trial_count_disclosure": { "type": "integer", "minimum": 0, "description": "Total trials evaluated. Must be honest even if MHT not applied." },
        "rejected_candidate_count": { "type": "integer", "minimum": 0 },
        "mht_block_reason": { "type": "string" }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["REJECT", "CONTINUE_RESEARCH", "CANDIDATE_FOR_V7_GATES", "BASELINE_VALID", "BASELINE_WEAK", "BLOCKED_FOR_MHT"],
      "description": "Overall verdict for this mode's research. BLOCKED_FOR_MHT when MHT not applied."
    },
    "blocked_scopes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Scopes that were blocked from research."
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Known limitations."
    },
    "recommended_actions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Recommended next steps."
    },
    "v7_gate_readiness": {
      "type": "object",
      "description": "P0.8E: per-mode V7 gate readiness assessment. Maps which gates this mode's evidence addresses.",
      "required": ["gates_mapped", "overall_readiness"],
      "properties": {
        "gates_mapped": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Canonical V7 gate IDs this mode's evidence covers."
        },
        "gates_not_ready": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Canonical V7 gate IDs not yet addressed."
        },
        "overall_readiness": {
          "type": "string",
          "enum": ["READY", "PARTIALLY_READY", "NOT_READY"],
          "description": "Overall readiness for V7 handoff."
        }
      }
    },
    "multiple_hypothesis_control": {
      "type": "object",
      "description": "P0.8E: MHT and data-snooping controls for this mode's research. Required — a report without MHT control carries a blocking hold.",
      "required": ["tested_hypothesis_count", "correction_method", "data_snooping_risk_flag"],
      "properties": {
        "tested_hypothesis_count": {
          "type": "integer",
          "description": "Total number of hypotheses/theses/feature-sets tested for this mode.",
          "minimum": 1
        },
        "correction_method": {
          "type": "string",
          "enum": ["FDR", "Bonferroni", "Deflated_Sharpe", "PBO", "NONE_APPLIED"],
          "description": "MHT correction method. NONE_APPLIED requires a blocking hold."
        },
        "corrected_significance": {
          "type": ["number", "null"],
          "description": "Significance after correction (null if NONE_APPLIED)."
        },
        "data_snooping_risk_flag": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"],
          "description": "Overall data-snooping risk assessment for this mode."
        },
        "deflated_sharpe_or_equivalent": {
          "type": ["number", "null"],
          "description": "Deflated Sharpe ratio or PBO risk assessment result."
        },
        "pbo_or_backtest_overfit_risk": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL", "NOT_RUN"],
          "description": "Probability of Backtest Overfit assessment."
        },
        "trial_count_disclosure": {
          "type": "integer",
          "description": "Number of trial configurations tested for this mode."
        },
        "rejected_candidate_count": {
          "type": "integer",
          "description": "Number of candidates rejected during this mode's research."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes on MHT methodology or limitations."
        }
      }
    }
  },
  "definitions": {
    "MetricWithCI": {
      "type": "object",
      "properties": {
        "value": { "type": "number" },
        "ci_lower": { "type": "number" },
        "ci_upper": { "type": "number" },
        "ci_level": { "type": "number", "description": "e.g., 0.95 for 95% CI." }
      }
    }
  }
}
