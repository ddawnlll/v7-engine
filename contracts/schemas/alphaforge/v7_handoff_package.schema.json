{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://v7-engine/contracts/schemas/alphaforge/v7_handoff_package.schema.json",
  "title": "V7HandoffPackage",
  "description": "The delivery artifact from AlphaForge to V7 acceptance gates. Bundles all evidence V7 needs to evaluate an alpha candidate. Owned by AlphaForge; accepted/rejected by V7. Gate IDs reference v7/docs/pipeline/evaluation.md as canonical source of truth. P0.8E: corrected gate mapping to match V7 canonical G0-G10 names.",
  "type": "object",
  "required": [
    "schema_version",
    "handoff_package_id",
    "mode",
    "alpha_candidate_id",
    "mode_research_report_id",
    "validation_report_id",
    "model_artifact_id",
    "calibration_candidate_id",
    "v7_gate_mapping",
    "recommended_status",
    "blocked_scopes",
    "limitations",
    "lineage"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "handoff_package_id": { "type": "string", "description": "Unique handoff package identifier." },
    "mode": { "type": "string", "enum": ["SCALP", "AGGRESSIVE_SCALP", "SWING"] },
    "alpha_candidate_id": { "type": "string", "description": "AlphaCandidate reference." },
    "mode_research_report_id": { "type": "string", "description": "ModeResearchReport reference." },
    "validation_report_id": { "type": "string", "description": "ValidationReport reference." },
    "model_artifact_id": { "type": "string", "description": "ModelArtifact reference." },
    "calibration_candidate_id": { "type": "string", "description": "CalibrationCandidate reference." },
    "v7_gate_mapping": {
      "type": "object",
      "description": "Mapping of AlphaForge evidence to V7 canonical promotion gates. Gate IDs match v7/docs/pipeline/evaluation.md exactly. P0.8E corrected from invented gate names to canonical V7 gate IDs.",
      "required": [
        "G0_doc_ready",
        "G1_research_backtest",
        "G2_walk_forward_oos",
        "G3_cost_stress",
        "G4_regime_breakdown",
        "G5_symbol_stability",
        "G6_calibration_reliability",
        "G7_shadow",
        "G8_paper",
        "G9_tiny_live",
        "G10_live"
      ],
      "properties": {
        "G0_doc_ready": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G0: DOC_READY" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        },
        "G1_research_backtest": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G1: RESEARCH_BACKTEST" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        },
        "G2_walk_forward_oos": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G2: WALK_FORWARD_OOS" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        },
        "G3_cost_stress": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G3: COST_STRESS" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        },
        "G4_regime_breakdown": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G4: REGIME_BREAKDOWN" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        },
        "G5_symbol_stability": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G5: SYMBOL_STABILITY" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        },
        "G6_calibration_reliability": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G6: CALIBRATION_RELIABILITY" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        },
        "G7_shadow": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G7: SHADOW (infrastructure not yet built)" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        },
        "G8_paper": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G8: PAPER (infrastructure not yet built)" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        },
        "G9_tiny_live": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G9: TINY_LIVE (infrastructure not yet built)" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        },
        "G10_live": {
          "type": "object",
          "required": ["evidence_ref", "status"],
          "properties": {
            "evidence_ref": { "type": "string", "description": "AlphaForge evidence ref for G10: LIVE (infrastructure not yet built)" },
            "status": { "type": "string", "enum": ["PASS", "PENDING", "NOT_EVALUATED"] }
          }
        }
      }
    },
    "recommended_status": {
      "type": "string",
      "enum": ["REVIEW_REQUIRED", "SHADOW_READY", "PROMOTION_CANDIDATE"],
      "description": "AlphaForge recommendation. V7 is NOT bound by this."
    },
    "blocked_scopes": { "type": "array", "items": { "type": "string" }, "description": "Scopes explicitly blocked/not covered." },
    "limitations": { "type": "array", "items": { "type": "string" }, "description": "Known limitations." },
    "lineage": {
      "type": "object",
      "description": "Full provenance chain from raw data to handoff.",
      "required": ["data_refs", "feature_set_id", "label_dataset_id", "simulation_profile_id", "lineage_verified"],
      "properties": {
        "data_refs": { "type": "array", "items": { "type": "string" } },
        "feature_set_id": { "type": "string" },
        "label_dataset_id": { "type": "string" },
        "simulation_profile_id": { "type": "string" },
        "simulation_run_ids": { "type": "array", "items": { "type": "string" } },
        "training_run_id": { "type": "string" },
        "git_commit": { "type": "string" },
        "lineage_verified": { "type": "boolean" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "rejection_rules_applied": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Which rejection rules were evaluated and passed before handoff. 12 V7 handoff rejection rules apply."
    }
  }
}